@{
    ViewData["Title"] = "Моя Статистика";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold" style="color: white;">Мій <span style="color: var(--accent-gold);">Профіль</span></h1>
        <p style="color: var(--text-muted);">Твоя читацька історія в цифрах</p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="p-4 rounded-4 shadow-lg text-center h-100" style="background: var(--card-bg); border: 1px solid var(--border-color);">
                <i class="bi bi-book-half display-4 mb-3" style="color: var(--accent-gold);"></i>
                <h2 class="display-5 fw-bold" style="color: white;">@ViewBag.TotalPagesRead</h2>
                <h5 style="color: var(--text-muted);">Всього прочитано сторінок</h5>
            </div>
        </div>

        <div class="col-md-5">
            <div class="p-4 rounded-4 shadow-lg text-center h-100" style="background: var(--card-bg); border: 1px solid var(--border-color);">
                <i class="bi bi-check-circle display-4 mb-3" style="color: #198754;"></i>
                <h2 class="display-5 fw-bold" style="color: white;">@ViewBag.FinishedBooks <span class="fs-4 text-muted">/ @ViewBag.TotalBooks</span></h2>
                <h5 style="color: var(--text-muted);">Завершено книг</h5>
            </div>
        </div>

        <div class="col-md-10 mt-4">
            <div class="p-4 rounded-4 shadow-lg text-center" style="background: var(--bg-dark); border: 1px dashed var(--accent-gold);">
                <h4 style="color: var(--text-muted);">Середній рейтинг твоїх книг</h4>
                <div class="display-3 fw-bold mt-2" style="color: var(--accent-gold);">
                    @ViewBag.AvgRating <i class="bi bi-star-fill fs-3"></i>
                </div>
            </div>
        </div>
    </div>
</div>